# ─── Seguridad ────────────────────────────────────────────────────────────────
JWT_SECRET=cambia-esto-minimo-32-caracteres-en-produccion
ENCRYPTION_KEY=cambia-esto-minimo-32-caracteres-en-produccion

# ─── Gemini AI ────────────────────────────────────────────────────────────────
# Obtén tu API key en: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...tu-clave-de-google-ai-studio

# ─── Base de Datos Turso (libSQL remoto) ──────────────────────────────────────
# Obtener en https://turso.tech → tu base de datos → Connect
TURSO_DATABASE_URL=libsql://tu-base.aws-region.turso.io
TURSO_AUTH_TOKEN=eyJhbGci...tu-token-de-turso

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Obtener en https://console.cloud.google.com → APIs & Services → Credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=tu-numero-proyecto-xxxxxx.apps.googleusercontent.com
# Client Secret — visible en Google Cloud Console al hacer clic en el cliente OAuth
GOOGLE_CLIENT_SECRET=tu-client-secret-de-google-cloud

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
